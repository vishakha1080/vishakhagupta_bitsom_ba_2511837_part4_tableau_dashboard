      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' datatype-customized='true' default-format='p0.00%' name='[Calculation_1764458717052928]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1764458717728769]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) - SUM([profit])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_1764458718273538]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_1764458719846404]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag])/COUNTD([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_1764458720575493]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN &quot;Fast (0-2 Days)&quot;&#13;&#10;&#13;&#10;ELSEIF [delivery_days] &lt;=5 THEN &quot;Medium (3-5 Days)&quot;&#13;&#10;&#13;&#10;ELSE &quot;Delayed (6+ Days)&quot;&#13;&#10;&#13;&#10;END' />
      </column>
